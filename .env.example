# ----------------------------------------------------------------------------
# Toko Online Sample — environment variables
# Copy to .env and adjust. NEVER commit real secrets.
# ----------------------------------------------------------------------------

# Public URL the app is served from (used for absolute links, webhooks, CORS)
APP_URL=http://localhost:3000

# Node server port
PORT=3000

# PostgreSQL (matches docker-compose.yml — host port 5434)
DATABASE_URL=postgres://toko:toko_secret@localhost:5434/toko

# Redis (matches docker-compose.yml — host port 6380)
REDIS_URL=redis://localhost:6380

# Auth / JWT — generate strong values for production: `openssl rand -base64 48`
AUTH_SECRET=dev-change-me-super-secret-session-key-change-in-prod
JWT_SECRET=dev-change-me-super-secret-jwt-signing-key-change-in-prod
# Access token TTL (seconds) and refresh token TTL (seconds)
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Webhook signing secret (HMAC-SHA256) for the mock payment provider
PAYMENT_WEBHOOK_SECRET=dev-change-me-webhook-hmac-secret

# CORS allowlist for the public API (comma-separated origins, or * for any)
API_CORS_ORIGINS=*

# Tax rate applied at checkout (PPN). 0.11 = 11%
TAX_RATE=0.11
# Flat shipping fee and free-shipping threshold (in smallest currency unit shown as integer rupiah)
SHIPPING_FLAT=20000
FREE_SHIPPING_THRESHOLD=300000
